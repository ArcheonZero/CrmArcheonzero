<Application x:Class="CrmArcheonzero.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CrmArcheonzero.Converters">
    <Application.Resources>
        <ResourceDictionary>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Views/Styles/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>


            <conv:BooleanToStrikethroughConverter x:Key="BooleanToStrikethrough"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:BoolToColorConverter x:Key="BoolToColor"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>