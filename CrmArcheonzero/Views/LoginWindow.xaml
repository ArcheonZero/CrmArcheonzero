<Window x:Class="CrmArcheonzero.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в CRM Archeonzero"
        Height="520"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- Отступ -->
            <RowDefinition Height="Auto"/>
            <!-- Логин -->
            <RowDefinition Height="Auto"/>
            <!-- Пароль -->
            <RowDefinition Height="Auto"/>
            <!-- Выбор БД [НОВОЕ] -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки -->
            <RowDefinition Height="Auto"/>
            <!-- Отступ -->
            <RowDefinition Height="Auto"/>
            <!-- Демо-блок -->
            <RowDefinition Height="*"/>
            <!-- Остальное пространство -->
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" 
                Background="#2A3B8C" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,20">
            <TextBlock Text="🔐 Вход в CRM Archeonzero"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- [ИЗМЕНЕНО] Поле: Выбор базы данных + кнопка подключения -->
        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="База данных:" FontWeight="Bold" Margin="0,0,0,5"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="ProviderComboBox" 
                  Grid.Column="0"
                  SelectedIndex="0"
                  Height="40"
                  Padding="5"
                  BorderBrush="#DDD"
                  BorderThickness="1"
                  VerticalContentAlignment="Center">
                    <ComboBoxItem Content="SQLite (локальная)" Tag="Sqlite"/>
                    <ComboBoxItem Content="SQL Server" Tag="SqlServer"/>
                    <ComboBoxItem Content="PostgreSQL" Tag="Postgre"/>
                </ComboBox>
                <Button Grid.Column="1" 
                Content="Подключиться"
                Click="Connect_Click"
                Margin="5,0,0,0"
                Padding="12,8"
                Background="#2A3B8C"
                Foreground="White"
                FontWeight="Bold"
                Cursor="Hand"/>
            </Grid>
        </StackPanel>

        <!-- Поле: Логин (изначально отключено) -->
        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Имя пользователя:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameBox" 
             Padding="10" 
             FontSize="14" 
             BorderBrush="#DDD" 
             BorderThickness="1"
             Height="40"
             IsEnabled="False"
             VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Поле: Пароль (изначально отключено) -->
        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="Пароль:" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" 
                 Padding="10" 
                 FontSize="14" 
                 BorderBrush="#DDD" 
                 BorderThickness="1"
                 Height="40"
                 IsEnabled="False"
                 VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Кнопки (Войти изначально отключена) -->
        <StackPanel Grid.Row="5" 
            Orientation="Horizontal" 
            HorizontalAlignment="Center" 
            Margin="0,5,0,15">
            <Button x:Name="LoginButton"
            Content="Войти"
            Click="Login_Click"
            Width="120"
            Height="40"
            Margin="5"
            IsEnabled="False"
            Background="#2A3B8C"
            Foreground="White"
            FontWeight="Bold"
            FontSize="14"
            Cursor="Hand"/>
            <Button Content="Отмена"
            Click="Cancel_Click"
            Width="120"
            Height="40"
            Margin="5"
            Background="#F5F5F5"
            Foreground="#333"
            FontWeight="Bold"
            FontSize="14"
            Cursor="Hand"/>
        </StackPanel>

        <!-- Демо-блок -->
        <Border Grid.Row="7" 
                Background="#FFF3E0" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,10,0,0">
            <StackPanel>
                <TextBlock Text="ℹ️ Демо доступ" 
                           FontWeight="Bold" 
                           Foreground="#E65100" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Логин: admin  |  Пароль: admin123" 
                           Foreground="#BF360C" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>