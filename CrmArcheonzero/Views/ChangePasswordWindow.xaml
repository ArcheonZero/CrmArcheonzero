<Window x:Class="CrmArcheonzero.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CRM Archeonzero — смена пароля" 
        Height="350" 
        Width="450"
        WindowStartupLocation="CenterOwner" 
        ResizeMode="NoResize"
        Background="White">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="#FF9800" 
                CornerRadius="5" 
                Padding="10" 
                Margin="0,0,0,20">
            <TextBlock Text="🔑 Смена пароля в CRM Archeonzero" 
                       FontSize="22" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Текущий пароль:" 
                       FontWeight="Bold" 
                       Margin="0,0,0,5"/>
            <PasswordBox x:Name="OldPasswordBox" 
                         Padding="10" 
                         FontSize="14"
                         BorderBrush="#DDD"
                         BorderThickness="1"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Новый пароль:" 
                       FontWeight="Bold" 
                       Margin="0,0,0,5"/>
            <PasswordBox x:Name="NewPasswordBox" 
                         Padding="10" 
                         FontSize="14"
                         BorderBrush="#DDD"
                         BorderThickness="1"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Подтвердите пароль:" 
                       FontWeight="Bold" 
                       Margin="0,0,0,5"/>
            <PasswordBox x:Name="ConfirmPasswordBox" 
                         Padding="10" 
                         FontSize="14"
                         BorderBrush="#DDD"
                         BorderThickness="1"/>
        </StackPanel>

        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center">
            <Button Content="Сменить пароль" 
                    Click="Change_Click" 
                    Width="140" 
                    Height="40" 
                    Margin="5"
                    Background="#FF9800" 
                    Foreground="White" 
                    FontWeight="Bold"
                    FontSize="14"
                    Cursor="Hand"/>
            
            <Button Content="Отмена" 
                    Click="Cancel_Click" 
                    Width="120" 
                    Height="40" 
                    Margin="5"
                    Background="#F5F5F5" 
                    Foreground="#333"
                    FontWeight="Bold"
                    FontSize="14"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>