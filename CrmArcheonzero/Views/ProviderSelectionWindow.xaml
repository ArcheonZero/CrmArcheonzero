<Window x:Class="CrmArcheonzero.Views.ProviderSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор базы данных" Height="250" Width="400"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <StackPanel Margin="20">
        <TextBlock Text="Выберите базу данных для подключения:" FontSize="16" Margin="0,0,0,20"/>
        <ComboBox x:Name="ProviderCombo" Margin="0,0,0,15" Height="30" FontSize="14"
                  SelectedIndex="0">
            <ComboBoxItem Content="PostgreSQL (облачная)" Tag="PostgreSQL" IsSelected="True"/>
            <ComboBoxItem Content="SQLite (локальная)" Tag="Sqlite"/>
            <ComboBoxItem Content="SQL Server" Tag="SqlServer"/>
        </ComboBox>
        <Button Content="Подключиться" Click="Connect_Click" Height="40" FontSize="14" 
                Background="#2A3B8C" Foreground="White" Cursor="Hand"/>
    </StackPanel>
</Window>