<UserControl x:Class="CrmArcheonzero.Views.Controls.TopPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CrmArcheonzero.ViewModels">

    <Border Background="{StaticResource SoftBackground}" 
            Padding="16" 
            CornerRadius="12" 
            Margin="0,0,0,12" 
            BorderBrush="{StaticResource BorderSoft}" 
            BorderThickness="1"
            Effect="{StaticResource ShadowEffect}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       Text="CRM Archeonzero" 
                       FontSize="20" 
                       FontWeight="SemiBold" 
                       Foreground="{StaticResource AccentDeepBlue}" 
                       VerticalAlignment="Center"/>

            <WrapPanel Grid.Column="1" 
                       HorizontalAlignment="Left" 
                       Margin="20,0,0,0" 
                       Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}">

                <Button Content="📤 Excel" 
                        Command="{Binding ExportExcelCommand}" 
                        Margin="3" Padding="8,4" 
                        Style="{StaticResource AccentButton}"/>
                <Button Content="🎂 ДР" 
                        Command="{Binding ShowBirthdaysCommand}" 
                        Margin="3" Padding="8,4" 
                        Style="{StaticResource AccentButton}"/>
                <Button Content="📧 Email" 
                        Command="{Binding SendEmailCommand}" 
                        Margin="3" Padding="8,4" 
                        Style="{StaticResource AccentButton}"/>
                <Button Content="📱 Telegram" 
                        Command="{Binding SendTelegramCommand}" 
                        Margin="3" Padding="8,4" 
                        Style="{StaticResource AccentButton}"/>
                <Button Content="📄 PDF" 
                        Command="{Binding ExportPdfCommand}" 
                        Margin="3" Padding="8,4" 
                        Style="{StaticResource AccentButton}"/>
                <Button Content="☁️ Backup" 
                        Command="{Binding BackupToCloudCommand}" 
                        Margin="3" Padding="8,4" 
                        Style="{StaticResource AccentButton}"/>
                <Separator Margin="5,0" Width="1" Background="{StaticResource BorderSoft}"/>
                <!--<Button Content="👥 Пользователи" 
                        Command="{Binding ShowUserManagementCommand}" 
                        Margin="3" Padding="8,4" 
                        Style="{StaticResource FlatButton}" 
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}" Click="Button_Click"/>-->
                <Button Content="🔑 Сменить пароль" 
                        Command="{Binding ChangePasswordCommand}" 
                        Margin="3" Padding="8,4" 
                        Style="{StaticResource FlatButton}"/>
                <!--<Button Content="🗑 Корзина" 
                        Command="{Binding OpenRecycleBinCommand}" 
                        Margin="3" Padding="8,4" 
                        Style="{StaticResource FlatButton}"
                        Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}"/>-->
            </WrapPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentUser.FullName, StringFormat='Меню Администратора — {0}'}" 
                           Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"
                           VerticalAlignment="Center" Margin="10,0" FontWeight="SemiBold" 
                           Foreground="{StaticResource TextDark}"/>
                <TextBlock Text="{Binding CurrentUser.FullName}" 
                           Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}"
                           VerticalAlignment="Center" Margin="10,0" FontWeight="SemiBold" 
                           Foreground="{StaticResource TextDark}"/>
                <Button Content="🔐 Войти" 
                        Command="{Binding LoginCommand}" 
                        Style="{StaticResource LoginButton}"
                        Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
                <Button Content="🚪 Выйти" 
                        Command="{Binding LogoutCommand}" 
                        Style="{StaticResource DangerButton}"
                        Visibility="{Binding IsAuthenticated, Converter={StaticResource BoolToVisibility}}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>