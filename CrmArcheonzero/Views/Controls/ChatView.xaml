<UserControl x:Class="CrmArcheonzero.Views.Controls.ChatView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CrmArcheonzero.ViewModels">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <ListView Grid.Row="0" 
                  ItemsSource="{Binding ChatMessages}" 
                  MaxHeight="400">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="0,5">
                        <TextBlock FontWeight="Bold">
                            <Run Text="{Binding UserName}" />
                            <Run Text=" — " />
                            <Run Text="{Binding SentAt, StringFormat=HH:mm}" Foreground="Gray"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBox Text="{Binding NewChatMessage, UpdateSourceTrigger=PropertyChanged}" 
         Width="300" Margin="0,0,5,0" 
         IsEnabled="{Binding IsAuthenticated}"
         BorderBrush="{StaticResource BorderSoft}" BorderThickness="1"/>
            <Button Content="Отправить" 
                    Command="{Binding SendChatMessageCommand}" 
                    Style="{StaticResource AccentButton}"
                    IsEnabled="{Binding IsAuthenticated}"/>
        </StackPanel>
    </Grid>
</UserControl>